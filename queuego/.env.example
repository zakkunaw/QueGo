# URL Proyek Supabase (ditemukan di Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here

# Anon Key Supabase (ditemukan di Project Settings -> API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service Role Key Supabase (ditemukan di Project Settings -> API - HANYA untuk backend)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Password Administrator untuk login ke Dashboard Admin
ADMIN_PASSWORD=your_admin_password_here
